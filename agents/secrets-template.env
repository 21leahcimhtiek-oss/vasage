# ===========================================
# Agent Secrets Configuration Template
# ===========================================
# Copy this file to .env and fill in your credentials
# Required secrets are marked with [REQUIRED]

# ===========================================
## GITHUB
# ===========================================
# [REQUIRED] GitHub Personal Access Token for API access
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ===========================================
## MICROSOFT STORE
# ===========================================
# [REQUIRED] Azure AD Tenant ID for Microsoft Store API
MS_STORE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [REQUIRED] Azure AD App Client ID
MS_STORE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [REQUIRED] Azure AD App Client Secret
MS_STORE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Microsoft Store App ID
MS_STORE_APP_ID=XXXXXXXXXXXX

# [REQUIRED] Azure Key Vault URL for code signing
AZURE_KEY_VAULT=https://your-vault.vault.azure.net/

# [REQUIRED] Azure Key Vault Certificate Name
AZURE_KEY_VAULT_CERTIFICATE=your-certificate-name

# [REQUIRED] Azure Client ID for code signing
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [REQUIRED] Azure Client Secret for code signing
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Azure Tenant ID for code signing
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===========================================
## GOOGLE PLAY
# ===========================================
# [REQUIRED] Google Play Service Account JSON (base64 encoded or path to file)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"xxx",...}

# [REQUIRED] Android package name (e.g., com.example.app)
ANDROID_PACKAGE_NAME=com.example.yourapp

# [REQUIRED] Android Keystore (base64 encoded)
ANDROID_KEYSTORE_BASE64=UEsDBBQAAAAI...

# [REQUIRED] Keystore password
ANDROID_KEYSTORE_PASSWORD=your_keystore_password

# [REQUIRED] Key alias within keystore
ANDROID_KEY_ALIAS=your_key_alias

# [REQUIRED] Key password
ANDROID_KEY_PASSWORD=your_key_password

# ===========================================
## VERCEL
# ===========================================
# [REQUIRED] Vercel API Token
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Vercel Organization ID
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Vercel Project ID
VERCEL_PROJECT_ID=QmXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
## API HUNTER (Optional)
# ===========================================
# [OPTIONAL] RapidAPI Key for enhanced API discovery
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] OpenAI API Key for AI-powered analysis
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
## NOTIFICATION CHANNELS (Optional)
# ===========================================
# [OPTIONAL] Slack Webhook URL for deployment notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# [OPTIONAL] Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ===========================================
## ADDITIONAL CONFIGURATION
# ===========================================
# Default deployment environment
DEFAULT_ENVIRONMENT=production

# Enable auto-deploy on push to main
AUTO_DEPLOY_ENABLED=false

# Require approval for production deployments
REQUIRE_PRODUCTION_APPROVAL=true

# ===========================================
## NETLIFY (FREE TIER: 100GB bandwidth)
# ===========================================
# [REQUIRED] Netlify Personal Access Token
NETLIFY_AUTH_TOKEN=nfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Netlify Site ID
NETLIFY_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===========================================
## RENDER (FREE TIER: 750 hours/month)
# ===========================================
# [REQUIRED] Render Deploy Hook URL
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxxxxxxxxxxx?key=xxxxxxxx

# ===========================================
## RAILWAY (FREE TIER: $5 credit/month)
# ===========================================
# [REQUIRED] Railway API Token
RAILWAY_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===========================================
## FLY.IO (FREE TIER: 3 shared-cpu-1x VMs)
# ===========================================
# [REQUIRED] Fly.io API Token
FLY_API_TOKEN=FlyV1 xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
## CLOUDFLARE PAGES (FREE TIER: Unlimited)
# ===========================================
# [REQUIRED] Cloudflare API Token
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Cloudflare Project Name
CLOUDFLARE_PROJECT_NAME=your-project-name

# ===========================================
## SUPABASE (FREE TIER: 500MB database)
# ===========================================
# [REQUIRED] Supabase Access Token
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Supabase Project ID
SUPABASE_PROJECT_ID=xxxxxxxxxxxxxxxxxxxxxxxx